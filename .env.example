# ================================================================
# vLLM 노드 목록
# 쉼표로 구분, 형식: host:port (vLLM 기본 포트 8000)
# ================================================================
VLLM_NODES=192.168.1.10:8000,192.168.1.11:8000

# vLLM 메트릭 엔드포인트 경로 (기본값: /metrics)
VLLM_METRICS_PATH=/metrics

# ================================================================
# nginx 설정 (기존 nginx가 외부에서 실행 중인 경우)
# nginx.conf에 아래 블록 추가 후 --profile nginx-metrics 로 exporter 활성화:
#
#   location /nginx_status {
#     stub_status;
#     allow 127.0.0.1;
#     deny all;
#   }
# ================================================================
NGINX_STUB_STATUS_URL=http://host.docker.internal/nginx_status

# ================================================================
# Prometheus 설정
# ================================================================
SCRAPE_INTERVAL=15s
# 스크레이프 타임아웃 — SCRAPE_INTERVAL보다 짧아야 함 (Prometheus 기본값은 10s)
# vLLM /metrics 응답이 느리거나(모델 다수/고카디널리티 히스토그램) 네트워크 경유가
# 있는 경우(Tailscale 등) "context deadline exceeded"가 뜨면 이 값을 올릴 것
SCRAPE_TIMEOUT=12s
EVALUATION_INTERVAL=15s
PROMETHEUS_RETENTION=15d

# Prometheus 로그 레벨 (debug/info/warn/error)
# 기본 info 레벨은 스크레이프 실패(타겟 다운, 타임아웃 등)를 로그에 남기지 않는다.
# 문제 진단 중에는 debug 유지, 평상시엔 warn 정도로 낮추는 것을 권장.
PROMETHEUS_LOG_LEVEL=debug

# 프론트엔드 새로고침 간격 (ms) — SCRAPE_INTERVAL과 맞추는 것을 권장
SCRAPE_INTERVAL_MS=15000

# ================================================================
# 포트 설정
# ================================================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
FRONTEND_PORT=8080

# nginx-exporter 포트 (docker compose --profile nginx-metrics 사용 시)
NGINX_EXPORTER_PORT=9113

# ================================================================
# Grafana 설정
# ================================================================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme
