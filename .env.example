# ================================================================
# vLLM 노드 목록
# 쉼표로 구분, 형식: host:port (vLLM 기본 포트 8000)
# ================================================================
VLLM_NODES=192.168.1.10:8000,192.168.1.11:8000

# vLLM 메트릭 엔드포인트 경로 (기본값: /metrics)
VLLM_METRICS_PATH=/metrics

# ================================================================
# nginx 설정 (기존 nginx가 외부에서 실행 중인 경우)
# nginx.conf에 아래 블록 추가 후 --profile nginx-metrics 로 exporter 활성화:
#
#   location /nginx_status {
#     stub_status;
#     allow 127.0.0.1;
#     deny all;
#   }
# ================================================================
NGINX_STUB_STATUS_URL=http://host.docker.internal/nginx_status

# ================================================================
# Prometheus 설정
# ================================================================
SCRAPE_INTERVAL=15s
EVALUATION_INTERVAL=15s
PROMETHEUS_RETENTION=15d

# 프론트엔드 새로고침 간격 (ms) — SCRAPE_INTERVAL과 맞추는 것을 권장
SCRAPE_INTERVAL_MS=15000

# ================================================================
# 포트 설정
# ================================================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
FRONTEND_PORT=8080

# nginx-exporter 포트 (docker compose --profile nginx-metrics 사용 시)
NGINX_EXPORTER_PORT=9113

# ================================================================
# Grafana 설정
# ================================================================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme
